# Public Sanity read-only configuration for the website frontend.
# These values are safe to expose because they do not include a write token.
VITE_SANITY_PROJECT_ID=upolphdd
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2026-07-20

# Optional Studio values for local reference. The Studio config is hard-wired to the existing project.
SANITY_STUDIO_PROJECT_ID=upolphdd
SANITY_STUDIO_DATASET=production
